<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>TechCore HR System</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI';
            background: #f4f6f9;
        }

        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            background: #111827;
            color: white;
            padding: 20px;
        }

        .sidebar h2 {
            margin-bottom: 20px;
        }

        .sidebar a {
            display: block;
            color: #cbd5e1;
            text-decoration: none;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .sidebar a:hover {
            background: #1f2937;
            color: white;
        }

        .main {
            margin-left: 260px;
            padding: 25px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }

        .title {
            font-size: 22px;
            font-weight: bold;
        }

        .subtitle {
            color: gray;
            font-size: 13px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }

        .btn {
            padding: 8px 12px;
            border-radius: 8px;
            text-decoration: none;
            color: white;
            font-size: 13px;
            margin-right: 5px;
        }

        .primary { background: #2563eb; }
        .success { background: #16a34a; }
        .danger { background: #dc2626; }
    </style>
</head>

<body>

<div class="sidebar">
    <h2>🏢 TechCore HR</h2>

    <a href="/Home">🏠 Dashboard</a>
    <a href="/Employees">👨‍💼 Employees</a>
    <a href="/Payroll">💰 Payroll</a>
</div>

<div class="main">
    @RenderBody()
</div>

</body>
</html>