@model IT15_LabExam_Braza.Models.Employee

<div class="card">

    <div class="title">Add Employee</div>
    <div class="subtitle">Enter employee details</div>

    <br />

    <form method="post">

        <label>First Name</label>
        <input name="FirstName" class="input" />

        <label>Last Name</label>
        <input name="LastName" class="input" />

        <label>Position</label>
        <input name="Position" class="input" />

        <label>Department</label>
        <input name="Department" class="input" />

        <label>Daily Rate</label>
        <input name="DailyRate" type="number" step="0.01" class="input" />

        <br /><br />

        <button class="btn success">Save</button>
        <a href="/Employees" class="btn primary">Back</a>

    </form>

</div>

<style>
    .input {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        margin-bottom: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
    }
</style>